					(thickness 0.15)
				)
			)
		)
		(property "Description" "V5_OR (12V-derived 5V OR'd with USB VBUS) to 3.3V LDO. Powers RP2040, RS-485 transceiver, FSR dividers, all panel logic. Low-dropout CMOS swap for AMS1117-3.3 (2026-07-16): ~360mV@1A vs ~1.1V dropout, fixes USB-VBUS-only headroom. Vin abs max 6V - must stay downstream of the 5V stage, never raw 12V. SOT223R ('ER' suffix ONLY - plain 'E' is pin-reversed) matches AMS1117 pinout GND/OUT/IN, tab=OUT. LCSC C3743528."
			(at 0 0 0)
			(unlocked yes)
			(layer "F.Fab")
			(hide yes)
			(uuid "c3cc427c-b39a-41fa-8bc9-28d4c03b1b73")
